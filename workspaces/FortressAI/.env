# Real local env file used by Docker Compose and local scripts.
# Location: /workspaces/FortressAI/.env

# Frontend -> Backend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Core backend
DATABASE_URL=postgresql+psycopg://fortress:fortress@postgres:5432/fortressai
REDIS_URL=redis://redis:6379/0
DEMO_TARGET=hkma.gov.hk
JWT_SECRET_KEY=fortressai-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Demo VPN mode (ExpressVPN only)
ENABLE_REAL_EXPRESSVPN=true
EXPRESSVPN_PROFILE=hk
ENABLE_REAL_FABRIC=true
FABRIC_PEER_ADDRESS=hyperledger:7051

# Blockchain API paths/base URLs
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
GOPLUS_BASE_URL=https://api.gopluslabs.io
METAMASK_PHISHING_URL=https://raw.githubusercontent.com/MetaMask/eth-phishing-detect/main/src/config.json
PHISHTANK_FEED_URL=https://data.phishtank.com/data/online-valid.json

# SIEM / cloud API paths
ELASTIC_INGEST_URL=
AWS_SECURITY_HUB_ENABLED=false
AWS_REGION=ap-east-1

# Alert providers
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=8508964628:AAFn-3O1CGrZ__BJ_4diXO3kTrEE07RS3Dg
TELEGRAM_CHAT_ID=
SENDGRID_API_KEY=
ALERT_EMAIL_FROM=alerts@fortressai.local
ALERT_EMAIL_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Cache / polling
REDIS_CACHE_TTL_SECONDS=900

